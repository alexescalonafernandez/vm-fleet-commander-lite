# VM Fleet Commander Lite
# B2.E5 - Multi-VM Bicep loop baseline
# File: 06-validate-bicep-vm-fleet.azcli
#
# Purpose:
# - Validate the VM fleet baseline before deployment.
# - Read runtime dynamic values and export them as environment variables.
# - Let .bicepparam resolve dynamic values via readEnvironmentVariable().
#
# Safety:
# - This file validates the deployment only.
# - It should not create Azure resources.
# - It reads the local public SSH key, not the private key.

$RG_NAME = "rg-b2-vmfleet-dev-we-01"
$LOCATION = "westeurope"
$DEPLOYMENT_NAME = "b2-vm-fleet-baseline-validation"
$PARAMETERS_FILE = "infra/parameters/dev.bicepparam"
$SSH_PUBLIC_KEY_PATH = "$HOME\.ssh\vm-b2-linux-01_key.pub"

# -------------------------------------------------------------------
# 1. Confirm Azure subscription
# -------------------------------------------------------------------

az account show --output table

# -------------------------------------------------------------------
# 2. Ensure the target Resource Group exists
# -------------------------------------------------------------------
# The Bicep deployment is resource-group scoped.
# This creates only the Resource Group, not the VM infrastructure.

az group create `
  --name $RG_NAME `
  --location $LOCATION `
  --output table

# -------------------------------------------------------------------
# 3. Confirm the local SSH public key exists
# -------------------------------------------------------------------

Test-Path $SSH_PUBLIC_KEY_PATH

# -------------------------------------------------------------------
# 4. Export runtime dynamic values for .bicepparam
# -------------------------------------------------------------------

$env:ADMIN_PUBLIC_KEY = (Get-Content $SSH_PUBLIC_KEY_PATH -Raw).Trim()
$MY_PUBLIC_IP = Invoke-RestMethod -Uri "https://api.ipify.org"
$env:SSH_SOURCE_ADDRESS_PREFIX = "$MY_PUBLIC_IP/32"

Write-Output "Resolved SSH source prefix: $env:SSH_SOURCE_ADDRESS_PREFIX"

# -------------------------------------------------------------------
# 5. Validate the Bicep deployment
# -------------------------------------------------------------------
# .bicepparam uses readEnvironmentVariable() to resolve dynamic values.

az deployment group validate `
  --resource-group $RG_NAME `
  --name $DEPLOYMENT_NAME `
  --parameters $PARAMETERS_FILE `
  --output table

# -------------------------------------------------------------------
# 6. Clean up transient environment variables
# -------------------------------------------------------------------

Remove-Item Env:\ADMIN_PUBLIC_KEY -ErrorAction SilentlyContinue
Remove-Item Env:\SSH_SOURCE_ADDRESS_PREFIX -ErrorAction SilentlyContinue

# VM Fleet Commander Lite
# B2.E2 - Bicep single VM baseline
# File: 08-inspect-bicep-single-vm.azcli
#
# Purpose:
# - Inspect the resources created by the Bicep deployment.
# - Capture VM state, Public IP, NIC, NSG, VNet and deployment outputs.
#
# Safety:
# - Read-only commands only.
# - Does not create, modify, or delete Azure resources.

$RG_NAME = "rg-b2-vmfleet-dev-we-01"
$VM_NAME = "vm-b2-linux-01"
$DEPLOYMENT_NAME = "b2-e2-bicep-single-vm"

# -------------------------------------------------------------------
# 1. List resources in the Resource Group
# -------------------------------------------------------------------

az resource list `
  --resource-group $RG_NAME `
  --output table

# -------------------------------------------------------------------
# 2. Show deployment outputs
# -------------------------------------------------------------------

az deployment group show `
  --resource-group $RG_NAME `
  --name $DEPLOYMENT_NAME `
  --query properties.outputs `
  --output json

# -------------------------------------------------------------------
# 3. Show VM details
# -------------------------------------------------------------------

az vm show `
  --resource-group $RG_NAME `
  --name $VM_NAME `
  --show-details `
  --output table

# -------------------------------------------------------------------
# 4. Show VM power state
# -------------------------------------------------------------------

az vm get-instance-view `
  --resource-group $RG_NAME `
  --name $VM_NAME `
  --query "instanceView.statuses[?starts_with(code, 'PowerState/')].displayStatus" `
  --output tsv

# -------------------------------------------------------------------
# 5. Show VM public IP
# -------------------------------------------------------------------

az vm list-ip-addresses `
  --resource-group $RG_NAME `
  --name $VM_NAME `
  --output table

# -------------------------------------------------------------------
# 6. Show NSG rules
# -------------------------------------------------------------------

$NSG_NAME = az deployment group show `
  --resource-group $RG_NAME `
  --name $DEPLOYMENT_NAME `
  --query "properties.outputs.nsgName.value" `
  --output tsv

az network nsg rule list `
  --resource-group $RG_NAME `
  --nsg-name $NSG_NAME `
  --output table

# -------------------------------------------------------------------
# 7. Show NICs
# -------------------------------------------------------------------

az network nic list `
  --resource-group $RG_NAME `
  --output table